<?xml version='1.0' encoding='utf-8' ?>

<!-- Tableau Data Source — подключение к CSV из data/ -->
<!-- Откройте в Tableau Desktop: Data → New Data Source → More... → Tableau Data Source -->

<datasource formatted-name='startup_ecosystem' inline='true' version='18.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <connection class='textscan' directory='../data' filename='company.csv' />
  <aliases enabled='yes' />
  <column caption='Company ID' datatype='integer' name='id' role='dimension' type='ordinal' />
  <column caption='Company Name' datatype='string' name='name' role='dimension' type='nominal' />
  <column caption='Category' datatype='string' name='category_code' role='dimension' type='nominal' />
  <column caption='Status' datatype='string' name='status' role='dimension' type='nominal' />
  <column caption='Country' datatype='string' name='country_code' role='dimension' type='nominal' />
  <column caption='Total Funding' datatype='real' name='funding_total' role='measure' type='quantitative' />
  <column caption='Milestones' datatype='integer' name='milestones' role='measure' type='quantitative' />
</datasource>
